FROM docker.io/node:lts-alpine

# lightweight development image with common build tools preinstalled
RUN apk add --no-cache git python3 make g++ \
  && npm install -g nx@latest webpack-cli

WORKDIR /workspace

ENV HOST=0.0.0.0
ENV PORT=3000

CMD ["sh", "-c", "if [ ! -d /workspace/node_modules ] || [ -z \"$(ls -A /workspace/node_modules)\" ]; then npm ci --prefer-offline --no-audit --progress=false; fi && npx nx run @org/nest_first:serve --configuration=development"]
